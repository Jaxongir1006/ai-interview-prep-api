# Local configuration
# Copy this file to local.yaml and modify as needed

service:
  name: interview-prep
  version: v0.1.0

logger:
  disable: false
  level: debug
  encoding: pretty

tracing:
  disable: true
  exporter_host: localhost
  exporter_port: 4317

alert:
  provider: noop
  telegram_bot_token: token
  telegram_chat_ids: []

postgres:
  verbose: true
  host: localhost
  port: 5432
  user: postgres
  password: postgres
  database: interview-prep

kafka_broker:
  brokers: localhost:9092

http_server:
  host: localhost
  port: 9876

cors:
  enabled: true
  allow_origins:
    - http://localhost:3000
    - http://localhost:5173
    - http://127.0.0.1:3000
    - http://127.0.0.1:5173
  allow_methods:
    - GET
    - POST
    - OPTIONS
  allow_headers:
    - Origin
    - Content-Type
    - Accept
    - Authorization
    - X-Requested-With
  expose_headers:
    - X-Trace-ID
  allow_credentials: true
  max_age: 86400

# Module specific configs

auth:
  mail:
    provider: smtp
    from_email: no-reply@hire-ready.local
    from_name: HireReady
    smtp:
      host: localhost
      port: 1025
  frontend_verify_email_url: http://localhost:3000/verify-email
  email_verification_token_ttl: 24h
  google_oauth:
    enabled: false
    client_id: your-google-client-id
  github_oauth:
    enabled: false
    client_id: your-github-client-id
    client_secret: your-github-client-secret
  access_token_ttl: 24h
  refresh_token_ttl: 168h # 7 days
  max_active_sessions: 5
  worker_poll_interval: 1s
  hashing_cost: 10

filevault:
  max_file_size_mb: 10
  minio:
    endpoint: localhost:9000
    access_key: minioadmin
    secret_key: minioadmin
    bucket: interview-prep

audit:
  worker_poll_interval: 1s

platform:
  worker_poll_interval: 1s
  alert_schema: alert
